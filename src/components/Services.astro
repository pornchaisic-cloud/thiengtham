---
export interface Props {
  locale?: Record<string, any>;
  lang?: string;
}

const { locale, lang } = Astro.props;
const t = locale;
const prefix = lang === 'en' ? '/en' : '';
---

<section class="section" id="services">
  <div class="container">
    <div class="section-title-wrapper reveal">
      <h2 class="section-title">{t.services.title}</h2>
      <div class="section-divider"></div>
    </div>
    <div class="services-grid">
      {
        t.services.items.map((item: any, i: number) => {
          const iconPaths = [
            ['M4 4h7v7H4z', 'M13 4h7v7h-7z', 'M4 13h7v7H4z', 'M13 13h7v7h-7z'],
            ['M3 21V4a1 1 0 0 1 1-1h16a1 1 0 0 1 1 1v17z', 'M9 9l2 4 2-3 4 7'],
            ['M9 3h6v1H9z', 'M7 4h10v2a4 4 0 0 1-4 4h-2a4 4 0 0 1-4-4V4z']
          ];
          const icons = iconPaths[i] || iconPaths[0];
          const hrefs = [`${prefix}/services/change-floor`, `${prefix}/services/fix-crack`, `${prefix}/services/painting`];
          return (
            <a href={hrefs[i]} class={`service-card card-premium reveal reveal-delay-${i + 1}`}>
              <div class="service-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--sun)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  {icons.map((d: string) => <path d={d}/>)}
                </svg>
              </div>
              <h3 class="service-title">{item.title}</h3>
              <p class="service-desc">{item.desc}</p>
            </a>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }
  .service-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: var(--space-xl) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    color: inherit;
    text-decoration: none;
    cursor: pointer;
  }
  .service-card:hover {
    color: inherit;
  }
  .service-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(200, 150, 46, 0.1), rgba(200, 150, 46, 0.04));
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(200, 150, 46, 0.08);
    transition: all 0.4s var(--ease-out-expo);
  }
  .service-title {
    font-family: var(--font-display-thai);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .service-desc {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }
  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
