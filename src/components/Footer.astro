---
export interface Props {
  lang?: string;
  locale?: Record<string, any>;
}

const { lang = "th", locale } = Astro.props;
const t = locale;
const isTH = lang === "th";
const otherLang = isTH ? "en" : "th";
const otherPath = isTH ? "/en" : "/";
---

<footer class="footer">
  <div class="container">
    <div class="footer-brand">✦ Thiengtham</div>
    <div class="footer-tagline">เที่ยงทำ ดีเวลลอปเม้นท์</div>
    <div class="footer-links">
      <a href={isTH ? "/#services" : "/en/#services"}>{t.nav.services}</a>
      <a href={isTH ? "/#portfolio" : "/en/#portfolio"}>{t.nav.portfolio}</a>
      <a href={isTH ? "/#contact" : "/en/#contact"}>{t.nav.contact}</a>
    </div>
    <div class="footer-divider"></div>
    <div class="footer-bottom">
      <span>{t.footer.copyright}</span>
      <span>Crafted with care</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--surface-elevated);
    border-top: 1px solid var(--border);
    padding: var(--space-xl) 0;
    transition: background 0.3s var(--ease-out-quart);
  }
  .footer-brand {
    font-family: var(--font-display-en);
    font-size: 1.2rem;
    color: var(--sun);
    font-weight: 500;
    text-align: left;
  }
  .footer-tagline {
    font-size: 0.75rem;
    opacity: 0.3;
    text-align: left;
    margin-top: 2px;
  }
  .footer-links {
    display: flex;
    justify-content: flex-start;
    gap: 32px;
    margin-top: 14px;
  }
  .footer-links a {
    font-size: 0.7rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover {
    color: var(--sun);
  }
  .footer-divider {
    border-top: 1px solid var(--border);
    margin: 16px auto 12px;
    max-width: 400px;
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .footer-bottom span {
    opacity: 0.18;
  }
  @media (max-width: 768px) {
    .footer-links {
      gap: 24px;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }
</style>