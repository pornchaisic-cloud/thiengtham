---
export interface Props {
  locale?: Record<string, any>;
}

const { locale } = Astro.props;
const t = locale;
---

<section class="section" id="portfolio">
  <div class="container">
    <div class="section-title-wrapper reveal">
      <h2 class="section-title">{t.portfolio.title}</h2>
      <div class="section-divider"></div>
    </div>

    <!-- Initial state: loading skeleton -->
    <div class="portfolio-loading reveal" id="portfolioLoading">
      <div class="skeleton-card"></div>
    </div>

    <!-- Photo variant: horizontal reel (carousel scroll-snap), client-rendered -->
    <div class="reel-track" id="reelTrack" hidden></div>

    <!-- Video variant: hero centered, client-rendered -->
    <div class="video-hero" id="videoHero" hidden></div>

    <div class="portfolio-caption" id="portfolioCaption" hidden>
      ซ่อมคอนโด ผลงานเที่ยงทำ ดีเวลลอปเม้นท์
    </div>
  </div>
</section>

<script>
  // Client-side fetch from /api/facebook-posts (Cloudflare Pages Function).
  // Strategy: use the LATEST post only.
  //   - 'video' → render hero <video controls> centered
  //   - 'photo' → render horizontal reel (scroll-snap) with all images
  //   - null / no items → hide everything (no SVG placeholder)
  async function loadPortfolio() {
    const loading = document.getElementById('portfolioLoading');
    const track = document.getElementById('reelTrack');
    const hero = document.getElementById('videoHero');
    const caption = document.getElementById('portfolioCaption');

    try {
      const res = await fetch('/api/facebook-posts');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const items = data.items || [];
      const type = data.type;

      if (loading) loading.hidden = true;

      if (!items.length || !type) {
        // No media on latest post — keep section minimal/hidden
        if (track) track.hidden = true;
        if (hero) hero.hidden = true;
        if (caption) caption.hidden = true;
        return;
      }

      if (type === 'video') {
        renderVideo(hero, items[0]);
        if (track) track.hidden = true;
      } else if (type === 'photo') {
        renderPhotos(track, items);
        if (hero) hero.hidden = true;
      }

      if (caption) caption.hidden = false;
    } catch (e) {
      // Site must stay usable even if FB API fails — hide everything gracefully
      console.warn('Failed to load portfolio:', e);
      if (loading) loading.hidden = true;
      if (track) track.hidden = true;
      if (hero) hero.hidden = true;
      if (caption) caption.hidden = true;
    }
  }

  function renderPhotos(track, items) {
    if (!track) return;
    track.hidden = false;
    track.innerHTML = items
      .map(
        (item) => `
        <a href="${escapeAttr(item.url || '#')}" target="_blank" rel="noopener" class="reel-card">
          <img src="${escapeAttr(item.src)}" alt="ผลงานเที่ยงทำ ดีเวลลอปเม้นท์" loading="lazy" />
        </a>
      `
      )
      .join('');
  }

  function renderVideo(hero, item) {
    if (!hero) return;
    hero.hidden = false;
    const poster = item.poster ? `poster="${escapeAttr(item.poster)}"` : '';
    hero.innerHTML = `
      <a href="${escapeAttr(item.url || '#')}" target="_blank" rel="noopener" class="video-frame">
        <video controls muted playsinline ${poster}>
          <source src="${escapeAttr(item.src)}" type="video/mp4">
        </video>
      </a>
    `;
    // Try to play muted on load (autoplay allowed when muted)
    const v = hero.querySelector('video');
    if (v) v.play().catch(() => {});
  }

  function escapeAttr(s) {
    return String(s || '').replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[c]));
  }

  loadPortfolio();
</script>

<style>
  /* Loading skeleton (only visible briefly while API loads) */
  .portfolio-loading {
    display: flex;
    justify-content: center;
    padding: 0 var(--space-md);
  }
  .skeleton-card {
    width: 100%;
    max-width: 320px;
    aspect-ratio: 3 / 4;
    background: var(--surface-soft);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    animation: skeleton-pulse 1.4s ease-in-out infinite;
  }
  @keyframes skeleton-pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 0.85; }
  }

  /* PHOTO variant — horizontal reel (carousel scroll-snap) */
  .reel-track {
    display: flex;
    gap: var(--space-md);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 8px var(--space-md) 20px;
    scrollbar-width: thin;
    scrollbar-color: var(--sun) var(--surface-soft);
  }
  .reel-track::-webkit-scrollbar { height: 6px; }
  .reel-track::-webkit-scrollbar-track { background: var(--surface-soft); }
  .reel-track::-webkit-scrollbar-thumb { background: var(--sun); border-radius: 3px; }
  .reel-track::before,
  .reel-track::after {
    content: '';
    flex: 0 0 calc(50vw - 160px);
    min-width: 16px;
  }
  .reel-card {
    flex: 0 0 320px;
    max-width: 80vw;
    scroll-snap-align: center;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
    aspect-ratio: 3 / 4;
    cursor: pointer;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.3s,
                box-shadow 0.3s;
    display: block;
  }
  .reel-card:hover {
    transform: scale(1.02);
    border-color: var(--sun);
    box-shadow: 0 12px 32px rgba(200, 150, 46, 0.15);
  }
  .reel-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* VIDEO variant — hero centered */
  .video-hero {
    display: flex;
    justify-content: center;
    padding: 0 var(--space-md);
  }
  .video-frame {
    display: block;
    width: 100%;
    max-width: 360px;
    aspect-ratio: 9 / 16;
    max-height: 80vh;
    background: var(--surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--sun);
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(200, 150, 46, 0.18);
    transition: transform 0.4s, box-shadow 0.4s;
  }
  .video-frame:hover {
    transform: scale(1.01);
    box-shadow: 0 16px 48px rgba(200, 150, 46, 0.28);
  }
  .video-frame video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .portfolio-caption {
    text-align: center;
    padding: 16px 0 0;
    font-size: 0.85rem;
    color: var(--muted);
    font-family: var(--font-display-thai);
  }

  /* Mobile: smaller card, tighter spacing */
  @media (max-width: 480px) {
    .reel-card { flex-basis: 78vw; }
    .reel-track::before,
    .reel-track::after { flex-basis: calc(50vw - 39vw); min-width: 8px; }
    .video-frame { max-width: 92vw; }
  }
</style>
