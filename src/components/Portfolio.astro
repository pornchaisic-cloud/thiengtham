---
export interface Props {
  locale?: Record<string, any>;
}

const { locale } = Astro.props;
const t = locale;
---

<section class="section" id="portfolio">
  <div class="container">
    <div class="section-title-wrapper reveal">
      <h2 class="section-title">{t.portfolio.title}</h2>
      <div class="section-divider"></div>
    </div>

    <!-- Initial state: loading skeleton (server-rendered, gets scoped styles) -->
    <div class="portfolio-loading reveal" id="portfolioLoading">
      <div class="skeleton-card"></div>
    </div>

    <!-- Photo variant: responsive grid (3/2/1 columns), client-rendered.
         Container is server-rendered, but the cards inside are generated
         by JS (see <script> below) — they don't get Astro's data-attr
         automatically, so the whole <style> block uses is:global. -->
    <div class="photo-grid" id="photoGrid" hidden></div>

    <!-- Video variant: hero centered, client-rendered (see <script>) -->
    <div class="video-hero" id="videoHero" hidden></div>

    <div class="portfolio-caption" id="portfolioCaption" hidden>
      ซ่อมคอนโด ผลงานเที่ยงทำ ดีเวลลอปเม้นท์
    </div>
  </div>
</section>

<script>
  // Client-side fetch from /api/facebook-posts (Cloudflare Pages Function).
  // Strategy: use the LATEST post only.
  //   - 'video' → render hero <video controls> centered
  //   - 'photo' → render responsive grid with all images (single or album)
  //   - null / no items → hide everything (no SVG placeholder)
  async function loadPortfolio() {
    const loading = document.getElementById('portfolioLoading');
    const grid = document.getElementById('photoGrid');
    const hero = document.getElementById('videoHero');
    const caption = document.getElementById('portfolioCaption');

    try {
      const res = await fetch('/api/facebook-posts');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const items = data.items || [];
      const type = data.type;

      if (loading) loading.hidden = true;

      if (!items.length || !type) {
        // No media on latest post — keep section minimal/hidden
        if (grid) grid.hidden = true;
        if (hero) hero.hidden = true;
        if (caption) caption.hidden = true;
        return;
      }

      if (type === 'video') {
        renderVideo(hero, items[0]);
        if (grid) grid.hidden = true;
      } else if (type === 'photo') {
        renderPhotoGrid(grid, items);
        if (hero) hero.hidden = true;
      }

      if (caption) caption.hidden = false;
    } catch (e) {
      // Site must stay usable even if FB API fails — hide everything gracefully
      console.warn('Failed to load portfolio:', e);
      if (loading) loading.hidden = true;
      if (grid) grid.hidden = true;
      if (hero) hero.hidden = true;
      if (caption) caption.hidden = true;
    }
  }

  function renderPhotoGrid(grid, items) {
    if (!grid) return;
    grid.hidden = false;
    grid.innerHTML = items
      .map(
        (item) => `
        <a href="${escapeAttr(item.url || '#')}" target="_blank" rel="noopener" class="photo-card">
          <img src="${escapeAttr(item.src)}" alt="ผลงานเที่ยงทำ ดีเวลลอปเม้นท์" loading="lazy" />
        </a>
      `
      )
      .join('');
  }

  function renderVideo(hero, item) {
    if (!hero) return;
    hero.hidden = false;
    const poster = item.poster ? `poster="${escapeAttr(item.poster)}"` : '';
    hero.innerHTML = `
      <a href="${escapeAttr(item.url || '#')}" target="_blank" rel="noopener" class="video-frame">
        <video controls muted playsinline ${poster}>
          <source src="${escapeAttr(item.src)}" type="video/mp4">
        </video>
      </a>
    `;
    // Try to play muted on load (autoplay allowed when muted)
    const v = hero.querySelector('video');
    if (v) v.play().catch(() => {});
  }

  function escapeAttr(s) {
    return String(s || '').replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[c]));
  }

  loadPortfolio();
</script>

<style is:global>
  /* NOTE: `is:global` is required because the photo cards / video frames /
   * inner <img>/<video> are generated CLIENT-SIDE by the <script> below.
   * Astro's default scoped style adds a `data-astro-cid-XXX` attribute to
   * server-rendered elements only — the JS-generated children don't have
   * it, so selectors like `.photo-card[data-astro-cid-uhrerali]` would
   * silently miss them, leaving the cards completely unstyled (no aspect
   * ratio, no border, no hover, no gold ring). Class names below are
   * unique to this component so making them global is safe. */

  /* Loading skeleton (only visible briefly while API loads) */
  .portfolio-loading {
    display: flex;
    justify-content: center;
    padding: 0 var(--space-md);
  }
  .skeleton-card {
    width: 100%;
    max-width: 320px;
    aspect-ratio: 3 / 4;
    background: var(--surface-soft);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    animation: skeleton-pulse 1.4s ease-in-out infinite;
  }
  @keyframes skeleton-pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 0.85; }
  }

  /* PHOTO variant — responsive grid that looks good for 1 OR many images.
   * auto-fit + justify-content:center keeps the row centered regardless
   * of how many cards the latest post has. */
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 380px));
    gap: 14px;
    justify-content: center;
    padding: 0 var(--space-md);
  }
  .photo-card {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
    cursor: pointer;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.3s,
                box-shadow 0.3s;
  }
  .photo-card:hover {
    transform: scale(1.03);
    border-color: var(--sun);
    box-shadow: 0 12px 32px rgba(200, 150, 46, 0.22);
    z-index: 1;
  }
  .photo-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (max-width: 620px) {
    .photo-grid { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  }

  /* VIDEO variant — hero centered */
  .video-hero {
    display: flex;
    justify-content: center;
    padding: 0 var(--space-md);
  }
  .video-frame {
    display: block;
    width: 100%;
    max-width: 360px;
    aspect-ratio: 9 / 16;
    max-height: 80vh;
    background: var(--surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--sun);
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(200, 150, 46, 0.18);
    transition: transform 0.4s, box-shadow 0.4s;
  }
  .video-frame:hover {
    transform: scale(1.01);
    box-shadow: 0 16px 48px rgba(200, 150, 46, 0.28);
  }
  .video-frame video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .portfolio-caption {
    text-align: center;
    padding: 16px 0 0;
    font-size: 0.85rem;
    color: var(--muted);
    font-family: var(--font-display-thai);
  }

  /* Mobile: tighter spacing */
  @media (max-width: 480px) {
    .video-frame { max-width: 92vw; }
  }
</style>
