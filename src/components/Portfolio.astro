---
export interface Props {
  locale?: Record<string, any>;
}

const { locale } = Astro.props;
const t = locale;
---

<section class="section" id="portfolio">
  <div class="container">
    <div class="section-title-wrapper reveal">
      <h2 class="section-title">{t.portfolio.title}</h2>
      <div class="section-divider"></div>
    </div>
    <div class="portfolio-masonry reveal" id="portfolioGrid">
      {[...Array(12)].map((_, i) => (
        <div
          class="portfolio-item"
          style={`transition-delay: ${i * 0.08}s`}
        >
          <div class="portfolio-placeholder">
            <svg viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="400" height="300" fill="var(--surface-soft)"/>
              <circle cx="200" cy="130" r="40" stroke="var(--muted)" stroke-width="1" opacity="0.3"/>
              <path d="M160 200l40-50 30 35 30-20 50 55H160z" fill="var(--muted)" opacity="0.15"/>
              <text x="200" y="260" text-anchor="middle" fill="var(--muted)" font-size="12" font-family="var(--font-display-thai)" opacity="0.5">{t.portfolio.title}</text>
            </svg>
          </div>
          <div class="portfolio-overlay">
            <span class="portfolio-label">{t.portfolio.title}</span>
          </div>
        </div>
      ))}
    </div>
    <div class="portfolio-caption">ซ่อมคอนโด ผลงานเที่ยงทำ ดีเวลลอปเม้นท์</div>
  </div>
</section>

<script>
  // Client-side fetch from /api/facebook-posts (Cloudflare Pages Function)
  // Replaces placeholders with real FB images from the LATEST post (album-aware).
  // If fetch fails or API returns no images, placeholders stay as fallback.
  async function loadPortfolio() {
    const grid = document.getElementById('portfolioGrid');
    if (!grid) return;

    try {
      const res = await fetch('/api/facebook-posts');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const images = data.images || [];
      if (images.length === 0) return;

      // Show latest-post caption/banner if present (helps visitor know what they're seeing)
      const postUrl = data?.meta?.postUrl;
      const slots = grid.querySelectorAll('.portfolio-item');
      images.forEach((img, i) => {
        if (slots[i]) {
          const targetUrl = img.url || postUrl || '#';
          slots[i].outerHTML = `
            <a href="${targetUrl}" target="_blank" rel="noopener" class="portfolio-item">
              <img src="${img.src}" alt="ซ่อมคอนโด ผลงานเที่ยงทำ ดีเวลลอปเม้นท์"
                   style="width:100%;height:auto;display:block;" loading="lazy" />
            </a>
          `;
        }
      });
    } catch (e) {
      // Site must stay usable even if FB API fails — keep placeholders
      console.warn('Failed to load portfolio images:', e);
    }
  }

  loadPortfolio();
</script>

<style>
  .portfolio-masonry {
    columns: 3;
    column-gap: var(--space-md);
  }
  .portfolio-item {
    break-inside: avoid;
    margin-bottom: var(--space-md);
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    border: 1px solid var(--border);
  }
  .portfolio-item:hover {
    transform: scale(1.02);
    border-color: var(--sun);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }
  .portfolio-placeholder {
    width: 100%;
    display: block;
    overflow: hidden;
  }
  .portfolio-placeholder svg {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .portfolio-item:hover .portfolio-placeholder svg {
    transform: scale(1.05);
  }
  .portfolio-item:nth-child(1) .portfolio-placeholder svg { height: 240px; }
  .portfolio-item:nth-child(2) .portfolio-placeholder svg { height: 300px; }
  .portfolio-item:nth-child(3) .portfolio-placeholder svg { height: 200px; }
  .portfolio-item:nth-child(4) .portfolio-placeholder svg { height: 280px; }
  .portfolio-item:nth-child(5) .portfolio-placeholder svg { height: 220px; }
  .portfolio-item:nth-child(6) .portfolio-placeholder svg { height: 260px; }
  .portfolio-item:nth-child(7) .portfolio-placeholder svg { height: 240px; }
  .portfolio-item:nth-child(8) .portfolio-placeholder svg { height: 300px; }
  .portfolio-item:nth-child(9) .portfolio-placeholder svg { height: 220px; }
  .portfolio-item:nth-child(10) .portfolio-placeholder svg { height: 280px; }
  .portfolio-item:nth-child(11) .portfolio-placeholder svg { height: 200px; }
  .portfolio-item:nth-child(12) .portfolio-placeholder svg { height: 260px; }

  .portfolio-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    align-items: flex-end;
    padding: var(--space-md);
  }
  .portfolio-item:hover .portfolio-overlay {
    opacity: 1;
  }
  .portfolio-caption {
    text-align: center;
    padding: 16px 0 0;
    font-size: 0.85rem;
    color: var(--muted);
    font-family: var(--font-display-thai);
  }
  .portfolio-label {
    font-family: var(--font-display-thai);
    font-size: 0.85rem;
    color: #fff;
  }
  @media (max-width: 768px) {
    .portfolio-masonry {
      columns: 2;
    }
  }
  @media (max-width: 480px) {
    .portfolio-masonry {
      columns: 1;
    }
  }
</style>