---
export interface Props {
  locale?: Record<string, any>;
}

const { locale } = Astro.props;
const t = locale;
---

<section class="hero" id="hero">
  <div class="hero-bg"></div>
  <canvas id="hero-canvas" aria-hidden="true"></canvas>
  <div class="container hero-content">
    <div class="hero-text reveal">
      <p class="hero-eyebrow">Thiengtham Development</p>
      <h1 class="hero-title">
        {t.hero.title}<br>
        <span class="hero-gold-line">{t.hero.titleGold}</span>
      </h1>
      <div class="hero-meta">
        <span>ตั้งแต่ 2015</span>
        <span class="dot">●</span>
        <span>200+ โปรเจกต์</span>
        <span class="dot">●</span>
        <span>รับเหมาซ่อมบ้าน-คอนโด</span>
      </div>
      <div class="hero-actions">
        <a href="https://line.me/R/ti/p/~@886gzgas" target="_blank" rel="noopener" class="btn-hero btn-hero-primary">
          {t.hero.cta}
        </a>
        <a href="#portfolio" class="btn-hero btn-hero-ghost">
          {t.hero.viewWork}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: var(--nav-height);
    background:
      radial-gradient(ellipse at 80% 20%, rgba(200,150,46,0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 20% 80%, rgba(200,150,46,0.04) 0%, transparent 50%);
  }
  #hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    padding-top: var(--space-xl);
    padding-bottom: var(--space-2xl);
  }
  .hero-text {
    text-align: center;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }
  .hero-eyebrow {
    font-family: var(--font-display-en);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .hero-title {
    font-family: var(--font-display-thai);
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 700;
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--ink);
  }
  .hero-gold-line {
    display: block;
    color: var(--sun);
    position: relative;
  }
  .hero-gold-line::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    right: 0;
    height: 12px;
    background: rgba(200,150,46,0.15);
    z-index: -1;
  }
  .hero-meta {
    display: flex;
    gap: 20px;
    margin-top: 12px;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .hero-meta span {
    opacity: 0.35;
  }
  .hero-meta .dot {
    opacity: 0.15;
    font-size: 0.35rem;
  }
  .hero-actions {
    margin-top: 16px;
    display: flex;
    gap: 12px;
  }
  .btn-hero {
    padding: 12px 28px;
    border-radius: 100px;
    font-family: var(--font-display-thai);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    transition: all 0.3s var(--ease-out-expo);
    cursor: pointer;
  }
  .btn-hero-primary {
    background: var(--sun);
    color: #0D0D0D;
    border: none;
  }
  .btn-hero-primary:hover {
    background: var(--sun-light);
    transform: translateY(-2px);
  }
  .btn-hero-ghost {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--border);
  }
  .btn-hero-ghost:hover {
    border-color: var(--sun);
    color: var(--sun);
    transform: translateY(-2px);
  }
  @media (max-width: 768px) {
    .hero-meta {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>

<script>
  (() => {
    const canvas = document.getElementById('hero-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');

    let W, H, dpr;
    let theme = document.documentElement.getAttribute('data-theme') || 'dark';
    let particles = [];
    let clouds = [];
    let time = 0;
    let animId = null;

    function resize() {
      dpr = window.devicePixelRatio || 1;
      const rect = canvas.parentElement.getBoundingClientRect();
      W = rect.width;
      H = rect.height;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width = W + 'px';
      canvas.style.height = H + 'px';
      ctx.scale(dpr, dpr);
    }

    // ===== Gold Particles (Dark mode) =====
    function initParticles() {
      const arr = [];
      for (let i = 0; i < 45; i++) {
        arr.push({
          x: Math.random() * W,
          y: Math.random() * H,
          size: 0.8 + Math.random() * 2.2,
          speedY: -(0.08 + Math.random() * 0.18),
          speedX: (Math.random() - 0.5) * 0.12,
          opacity: 0.15 + Math.random() * 0.4,
          phase: Math.random() * Math.PI * 2,
          freq: 0.004 + Math.random() * 0.008,
        });
      }
      return arr;
    }

    function drawParticles() {
      for (const p of particles) {
        p.y += p.speedY;
        p.x += p.speedX + Math.sin(time * p.freq + p.phase) * 0.3;
        if (p.y < -p.size) { p.y = H + p.size; p.x = Math.random() * W; }
        if (p.x < -p.size) p.x = W + p.size;
        if (p.x > W + p.size) p.x = -p.size;
        const pulse = 0.65 + 0.35 * Math.sin(time * 0.015 + p.phase + 1);
        const alpha = p.opacity * pulse;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(200, 150, 46, ' + alpha.toFixed(3) + ')';
        ctx.fill();
        if (p.size > 1.2) {
          ctx.shadowColor = 'rgba(200, 150, 46, ' + (alpha * 0.25).toFixed(3) + ')';
          ctx.shadowBlur = p.size * 4;
          ctx.fill();
          ctx.shadowBlur = 0;
        }
      }
    }

    // ===== Gold Sand Clouds (Light mode) =====
    function createCloud() {
      const blobCount = 35 + Math.floor(Math.random() * 20);
      const goldColors = [
        '200,150,46', '212,168,67', '190,140,40',
        '218,178,80', '180,130,35', '232,188,90',
      ];
      const blobs = [];
      for (let i = 0; i < blobCount; i++) {
        const angle = Math.random() * Math.PI * 2;
        const dist = 20 + Math.random() * 130;
        blobs.push({
          ox: Math.cos(angle) * dist,
          oy: Math.sin(angle) * dist * 0.6,
          rx: 25 + Math.random() * 75,
          ry: 20 + Math.random() * 55,
          color: goldColors[Math.floor(Math.random() * goldColors.length)],
          maxAlpha: 0.04 + Math.random() * 0.09,
          phase: Math.random() * Math.PI * 2,
        });
      }
      return {
        x: Math.random() * W * 1.5 - W * 0.25,
        y: Math.random() * H * 1.3 - H * 0.15,
        blobs,
        speedX: 0.2 + Math.random() * 0.25,
        speedY: -0.02 + Math.random() * 0.04,
        driftPhase: Math.random() * Math.PI * 2,
        driftAmpX: 0.15 + Math.random() * 0.2,
        driftAmpY: 0.08 + Math.random() * 0.12,
        driftFreq: 0.004 + Math.random() * 0.006,
        scale: 0.9 + Math.random() * 0.6,
      };
    }

    function initClouds() {
      const arr = [];
      for (let i = 0; i < 4; i++) arr.push(createCloud());
      return arr;
    }

    function drawClouds() {
      for (const cloud of clouds) {
        cloud.x += cloud.speedX + Math.sin(time * cloud.driftFreq + cloud.driftPhase) * cloud.driftAmpX;
        cloud.y += cloud.speedY + Math.cos(time * cloud.driftFreq * 0.7 + cloud.driftPhase) * cloud.driftAmpY;
        const maxX = W + 300;
        const minX = -400;
        if (cloud.x > maxX) { cloud.x = minX; cloud.y = 0.1 + Math.random() * 0.8 * H; }
        if (cloud.x < minX - 100) { cloud.x = maxX; cloud.y = Math.random() * H; }
        const s = cloud.scale;
        for (const b of cloud.blobs) {
          const px = cloud.x + b.ox * s;
          const py = cloud.y + b.oy * s;
          const pulse = 0.7 + 0.3 * Math.sin(time * 0.01 + b.phase);
          const alpha = b.maxAlpha * pulse;
          const grad = ctx.createRadialGradient(px, py, 0, px, py, b.rx * s);
          const innerAlpha = alpha.toFixed(4);
          const midAlpha = (alpha * 0.5).toFixed(4);
          grad.addColorStop(0, 'rgba(' + b.color + ',' + innerAlpha + ')');
          grad.addColorStop(0.25, 'rgba(' + b.color + ',' + innerAlpha + ')');
          grad.addColorStop(0.5, 'rgba(' + b.color + ',' + midAlpha + ')');
          grad.addColorStop(1, 'rgba(' + b.color + ',0)');
          ctx.beginPath();
          ctx.ellipse(px, py, b.rx * s, b.ry * s, 0, 0, Math.PI * 2);
          ctx.fillStyle = grad;
          ctx.fill();
        }
      }
    }

    // ===== Main loop =====
    function draw() {
      ctx.clearRect(0, 0, W, H);
      if (theme === 'light') {
        drawClouds();
      } else {
        drawParticles();
      }
    }

    function loop() {
      time++;
      draw();
      animId = requestAnimationFrame(loop);
    }

    // ===== Theme switch =====
    function applyTheme(t) {
      theme = t;
      if (theme === 'light') {
        clouds = initClouds();
        particles = [];
      } else {
        particles = initParticles();
        clouds = [];
      }
    }

    // ===== Init =====
    function init() {
      resize();
      applyTheme(theme);
      loop();
    }

    window.addEventListener('resize', () => {
      resize();
      for (const p of particles) {
        if (p.x > W) p.x = W * Math.random();
        if (p.y > H) p.y = H * Math.random();
      }
    });

    if (window.ResizeObserver) {
      const ro = new ResizeObserver(() => resize());
      ro.observe(canvas.parentElement);
    }

    // Watch theme changes on <html>
    const observer = new MutationObserver(() => {
      const t = document.documentElement.getAttribute('data-theme') || 'dark';
      if (t !== theme) applyTheme(t);
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    init();
  })();
</script>