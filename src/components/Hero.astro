---
export interface Props {
  locale?: Record<string, any>;
}

const { locale } = Astro.props;
const t = locale;
---

<section class="hero" id="hero">
  <div class="hero-bg"></div>
  <div class="container hero-content">
    <div class="hero-text">
      <h1 class="hero-title">{t.hero.title}</h1>
      <p class="hero-subtitle">{t.hero.subtitle}</p>
      <p class="hero-desc">{t.hero.desc}</p>
      <a href="https://line.me/R/ti/p/~@886gzgas" target="_blank" rel="noopener" class="btn btn-primary hero-cta">
        <span>{t.hero.cta}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
    <div class="hero-visual">
      <div class="hero-symbol">
        <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="100" cy="100" r="80" stroke="var(--sun)" stroke-width="1" opacity="0.2"/>
          <circle cx="100" cy="100" r="60" stroke="var(--sun)" stroke-width="1" opacity="0.4"/>
          <circle cx="100" cy="100" r="40" fill="var(--sun)" opacity="0.15"/>
          <circle cx="100" cy="98" r="18" fill="var(--sun)" opacity="0.6"/>
          <circle cx="100" cy="92" r="10" fill="var(--sun-light)" opacity="0.9"/>
          <rect x="82" y="30" width="36" height="3" rx="1.5" fill="var(--sun-light)" opacity="0.3"/>
          <rect x="78" y="38" width="44" height="2" rx="1" fill="var(--sun-light)" opacity="0.2"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: var(--nav-height);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--brand) 0%, var(--brand-soft) 100%);
    z-index: 0;
  }
  [data-theme="light"] .hero-bg {
    background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
    padding-top: var(--space-xl);
    padding-bottom: var(--space-2xl);
  }
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .hero-title {
    font-family: var(--font-display-thai);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--sun-light);
    line-height: 1.15;
  }
  .hero-subtitle {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-weight: 500;
    color: var(--sun);
  }
  .hero-desc {
    font-size: clamp(0.95rem, 1.5vw, 1.125rem);
    color: rgba(255, 255, 255, 0.6);
    max-width: 480px;
  }
  .hero-cta {
    margin-top: var(--space-md);
    align-self: flex-start;
  }
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero-symbol {
    width: clamp(160px, 25vw, 280px);
    height: clamp(160px, 25vw, 280px);
    animation: float 6s var(--ease-out-expo) infinite;
  }
  .hero-symbol svg {
    width: 100%;
    height: 100%;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-16px); }
  }
  @media (max-width: 768px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-xl);
    }
    .hero-cta {
      align-self: center;
    }
    .hero-desc {
      max-width: none;
    }
    .hero-visual {
      order: -1;
    }
    .hero-symbol {
      width: 120px;
      height: 120px;
    }
  }
</style>
