---
export interface Props {
  locale?: Record<string, any>;
}

const { locale } = Astro.props;
const t = locale;
---

<section class="hero" id="hero">
  <div class="hero-bg"></div>
  <div class="container hero-content">
    <div class="hero-text reveal">
      <p class="hero-eyebrow">Thiengtham Development</p>
      <h1 class="hero-title">
        {t.hero.title}<br>
        <span class="hero-gold-line">{t.hero.titleGold}</span>
      </h1>
      <div class="hero-meta">
        <span>ตั้งแต่ 2015</span>
        <span class="dot">●</span>
        <span>200+ โปรเจกต์</span>
        <span class="dot">●</span>
        <span>รับเหมาซ่อมบ้าน-คอนโด</span>
      </div>
      <div class="hero-actions">
        <a href="https://line.me/R/ti/p/~@886gzgas" target="_blank" rel="noopener" class="btn-hero btn-hero-primary">
          {t.hero.cta}
        </a>
        <a href="#portfolio" class="btn-hero btn-hero-ghost">
          {t.hero.viewWork}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: var(--nav-height);
    background:
      radial-gradient(ellipse at 80% 20%, rgba(200,150,46,0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 20% 80%, rgba(200,150,46,0.04) 0%, transparent 50%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    padding-top: var(--space-xl);
    padding-bottom: var(--space-2xl);
  }
  .hero-text {
    text-align: center;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }
  .hero-eyebrow {
    font-family: var(--font-display-en);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .hero-title {
    font-family: var(--font-display-thai);
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 700;
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--ink);
  }
  .hero-gold-line {
    display: block;
    color: var(--sun);
    position: relative;
  }
  .hero-gold-line::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    right: 0;
    height: 12px;
    background: rgba(200,150,46,0.15);
    z-index: -1;
  }
  .hero-meta {
    display: flex;
    gap: 20px;
    margin-top: 12px;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .hero-meta span {
    opacity: 0.35;
  }
  .hero-meta .dot {
    opacity: 0.15;
    font-size: 0.35rem;
  }
  .hero-actions {
    margin-top: 16px;
    display: flex;
    gap: 12px;
  }
  .btn-hero {
    padding: 12px 28px;
    border-radius: 100px;
    font-family: var(--font-display-thai);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    transition: all 0.3s var(--ease-out-expo);
    cursor: pointer;
  }
  .btn-hero-primary {
    background: var(--sun);
    color: #0D0D0D;
    border: none;
  }
  .btn-hero-primary:hover {
    background: var(--sun-light);
    transform: translateY(-2px);
  }
  .btn-hero-ghost {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--border);
  }
  .btn-hero-ghost:hover {
    border-color: var(--sun);
    color: var(--sun);
    transform: translateY(-2px);
  }
  @media (max-width: 768px) {
    .hero-meta {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>