---
export interface Props {
  locale?: Record<string, any>;
}

const { locale } = Astro.props;
const t = locale;
---

<section class="section" id="contact">
  <div class="container">
    <div class="section-label reveal">Contact</div>
    <div class="contact-block reveal">
      <div class="contact-tagline">
        {t.contact.tagline}
      </div>
      <div class="contact-channels">
        <a href="https://line.me/R/ti/p/~@886gzgas" target="_blank" rel="noopener" class="ch">
          <span class="ch-label">{t.contact.line}</span>
          <span class="ch-value gold">@886gzgas</span>
        </a>
        <a href="tel:0620698888" class="ch">
          <span class="ch-label">{t.contact.phone}</span>
          <span class="ch-value">062-069-8888</span>
        </a>
        <a href="https://www.facebook.com/ThiengTham.DEV" target="_blank" rel="noopener" class="ch">
          <span class="ch-label">{t.contact.facebook}</span>
          <span class="ch-value">ThiengTham.DEV</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    padding: 20px 0;
  }
  .contact-tagline {
    font-family: var(--font-display-en);
    font-size: 1.15rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--ink);
    max-width: 360px;
  }
  .contact-channels {
    display: flex;
    flex-direction: column;
  }
  .ch {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: all 0.2s;
  }
  .ch:hover {
    padding-left: 8px;
  }
  .ch-label {
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--muted);
    min-width: 70px;
  }
  .ch-value {
    font-family: var(--font-display-thai);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .ch-value.gold {
    color: var(--sun);
  }
  @media (max-width: 768px) {
    .contact-block {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>