---
export interface Props {
  locale?: Record<string, any>;
}

const { locale } = Astro.props;
const t = locale;
---

<section class="section" id="why-us">
  <div class="container">
    <div class="section-title-wrapper reveal">
      <h2 class="section-title">{t.whyus.title}</h2>
      <div class="section-divider"></div>
    </div>
    <div class="whyus-grid">
      {
        t.whyus.items.map((item: any, i: number) => (
          <div class={`whyus-card reveal reveal-delay-${i + 1}`}>
            <div class="whyus-icon">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="var(--sun)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                {item.icon === 'clock' && <><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></>}
                {item.icon === 'shield' && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></>}
                {item.icon === 'map' && <><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></>}
                {item.icon === 'message' && <><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></>}
              </svg>
            </div>
            <h3 class="whyus-title">{item.title}</h3>
            <p class="whyus-desc">{item.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .whyus-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }
  .whyus-card {
    text-align: center;
    padding: var(--space-xl) var(--space-md);
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--card-bg);
    transition: all 0.4s var(--ease-out-expo);
  }
  :global([data-theme="dark"]) .whyus-card {
    border: 1px solid rgba(255,255,255,0.06);
  }
  .whyus-card:hover {
    border-color: rgba(200, 150, 46, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .whyus-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(200,150,46,0.12), rgba(200,150,46,0.04));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md);
    border: 1px solid rgba(200,150,46,0.08);
  }
  .whyus-title {
    font-family: var(--font-display-thai);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
    letter-spacing: -0.01em;
  }
  .whyus-desc {
    color: var(--muted);
    font-size: 0.85rem;
    line-height: 1.6;
  }
  @media (max-width: 768px) {
    .whyus-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .whyus-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
